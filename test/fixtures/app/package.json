{
  "name": "kelo-fixture",
  "productName": "KeloFixture",
  "version": "1.0.0",
  "description": "kelo E2E fixture app",
  "author": "kelo <noreply@example.co>",
  "main": "dist-electron/launcher.cjs",
  "dependencies": {
    "kelo": "*"
  },
  "build": {
    "appId": "dev.kelo.fixture",
    "electronVersion": "42.3.0",
    "asar": true,
    "asarUnpack": [
      "node_modules/kelo/**"
    ],
    "files": [
      "dist/**",
      "dist-electron/**",
      "node_modules/kelo/**",
      "package.json"
    ],
    "directories": {
      "output": "release"
    },
    "publish": [
      {
        "provider": "generic",
        "url": "http://127.0.0.1/feed"
      }
    ],
    "mac": {
      "target": [
        "zip"
      ],
      "identity": null
    },
    "win": {
      "target": [
        "nsis"
      ]
    },
    "linux": {
      "target": [
        "dir"
      ]
    }
  }
}
