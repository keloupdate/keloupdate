{
  "name": "kelo",
  "version": "0.1.0",
  "description": "Hot updates for Electron apps. Push code to running apps in 5 seconds.",
  "type": "module",
  "bin": {
    "kelo": "./dist/cli.js"
  },
  "main": "./dist/updater.js",
  "exports": {
    ".": "./dist/updater.js",
    "./react": "./dist/react.js",
    "./launcher": "./dist/launcher.cjs"
  },
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "test": "node --experimental-strip-types --test test/*.test.ts",
    "test:e2e:cli": "node --experimental-strip-types --test test/e2e/*.cli.test.ts",
    "test:e2e": "playwright test"
  },
  "files": [
    "dist",
    "launcher.cjs"
  ],
  "keywords": [
    "electron",
    "hot-update",
    "ota",
    "updater",
    "deploy"
  ],
  "license": "MIT",
  "dependencies": {
    "tus-js-client": "^4.3.1"
  },
  "devDependencies": {
    "@playwright/test": "^1.60.0",
    "@types/node": "^22.0.0",
    "@types/react": "^19.2.14",
    "electron": "^42.3.0",
    "electron-builder": "^26.8.1",
    "playwright": "^1.60.0",
    "tsup": "^8.0.0",
    "typescript": "^5.5.0"
  },
  "peerDependencies": {
    "electron": ">=25.0.0",
    "react": ">=18.0.0"
  },
  "peerDependenciesMeta": {
    "react": {
      "optional": true
    }
  }
}
